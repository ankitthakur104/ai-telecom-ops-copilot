# Application
  DEBUG=false
  LOG_LEVEL=INFO

  # OpenAI — required
  OPENAI_API_KEY=sk-...

  # PostgreSQL
  DATABASE_URL=postgresql+asyncpg://telecom:telecom@localhost:5432/telecom_copilot

  # Redis
  REDIS_URL=redis://localhost:6379/0

  # Qdrant
  QDRANT_URL=http://localhost:6333
  QDRANT_COLLECTION=telecom_incidents

  # Neo4j
  NEO4J_URL=bolt://localhost:7687
  NEO4J_USER=neo4j
  NEO4J_PASSWORD=telecom123

  # Kafka
  KAFKA_BOOTSTRAP_SERVERS=localhost:9092
  KAFKA_ALERT_TOPIC=telecom.alerts

  # Keycloak
  KEYCLOAK_URL=http://localhost:8080
  KEYCLOAK_REALM=telecom-copilot
  KEYCLOAK_CLIENT_ID=copilot-backend
  KEYCLOAK_CLIENT_SECRET=your-client-secret
  