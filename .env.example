# Application
  DEBUG=false
  LOG_LEVEL=INFO

  # OpenAI — required
  OPENAI_API_KEY=sk-...

  # PostgreSQL
  DATABASE_URL=postgresql+asyncpg://telecom:telecom@localhost:5432/telecom_copilot

  # Redis
  REDIS_URL=redis://localhost:6379/0

  # Qdrant
  QDRANT_URL=http://localhost:6333

  # Neo4j
